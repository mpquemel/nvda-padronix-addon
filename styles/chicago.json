{
  "name": "Chicago",
  "description": "Chicago Manual of Style - 17th Edition",
  "country": "USA",
  "language": "en",
  "font": "Times New Roman",
  "font_size": 12,
  "margins": {
    "top": 2.54,
    "bottom": 2.54,
    "left": 2.54,
    "right": 2.54
  },
  "spacing": 2.0,
  "paragraph_spacing": 0.0,
  "alignment": "left",
  "page_size": "Letter",
  "header": {
    "enabled": false
  },
  "footer": {
    "enabled": true,
    "page_numbers": true
  },
  "title_page": {
    "title_spacing": 1.5,
    "elements": ["title", "author", "course", "instructor", "date"]
  },
  "sections": {
    "abstract": {
      "heading": "Abstract",
      "bold": true,
      "alignment": "center"
    },
    "introduction": {
      "heading": "Introduction"
    },
    "references": {
      "heading": "Bibliography",
      "hanging_indent": 1.27
    }
  },
  "citations": {
    "style": "notes-bibliography",
    "format": "footnote"
  }
}
