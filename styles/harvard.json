{
  "name": "Harvard",
  "description": "Harvard Referencing Style",
  "country": "UK",
  "language": "en",
  "font": "Times New Roman",
  "font_size": 12,
  "margins": {
    "top": 2.54,
    "bottom": 2.54,
    "left": 2.54,
    "right": 2.54
  },
  "spacing": 2.0,
  "paragraph_spacing": 0.0,
  "alignment": "left",
  "page_size": "A4",
  "header": {
    "enabled": false
  },
  "footer": {
    "enabled": true,
    "page_numbers": true
  },
  "title_page": {
    "title_spacing": 1.5,
    "elements": ["title", "author", "institution", "date"]
  },
  "sections": {
    "abstract": {
      "heading": "Abstract",
      "bold": true
    },
    "introduction": {
      "heading": "1. Introduction"
    },
    "references": {
      "heading": "References",
      "hanging_indent": 1.27,
      "alphabetical": true
    }
  },
  "citations": {
    "style": "author-date",
    "format": "(Author, Year)"
  }
}
